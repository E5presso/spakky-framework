{
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(uv lock *)",
      "Bash(uv add *)",
      "Bash(uv pip *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git rebase*)",
      "Bash(git stash*)",
      "Bash(git worktree*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh api*)",
      "Bash(gh run *)",
      "Bash(gh label *)",
      "Bash(gh workflow view*)",
      "Bash(gh workflow list*)",
      "Bash(rtk *)",
      "EnterWorktree",
      "ExitWorktree",
      "SendMessage",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskRead",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir | grep -q worktrees && git fetch origin develop -q && git rebase --autostash origin/develop -q || true",
            "timeout": 30,
            "statusMessage": "Rebasing worktree onto origin/develop..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; [[ \"$f\" == *.py ]] && cd \"$(git rev-parse --show-toplevel)\" && uv run ruff format \"$f\" && uv run ruff check --fix \"$f\"; } 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "Formatting with ruff..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; [[ \"$f\" == *.py ]] && cd \"$(git rev-parse --show-toplevel)\" && result=$(uv run pyrefly check \"$f\" 2>&1) && exit 0 || echo \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PostToolUse\\\",\\\"additionalContext\\\":\\\"pyrefly type check errors in $f:\\n$result\\\"}}\"; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Type checking with pyrefly..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "pyrefly-lsp@local": true
  },
  "extraKnownMarketplaces": {
    "local": {
      "source": {
        "source": "directory",
        "path": ".claude/plugins/pyrefly-lsp"
      }
    }
  },
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "30000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
