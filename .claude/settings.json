{
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(uv lock *)",
      "Bash(uv add *)",
      "Bash(uv pip *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git rebase*)",
      "Bash(git stash*)",
      "Bash(git worktree*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh api*)",
      "Bash(gh run *)",
      "Bash(gh label *)",
      "Bash(gh workflow view*)",
      "Bash(gh workflow list*)",
      "Bash(rtk *)",
      "EnterWorktree",
      "ExitWorktree",
      "SendMessage",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskRead",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir | grep -q worktrees && git fetch origin develop -q && git rebase --autostash origin/develop -q || true",
            "timeout": 30,
            "statusMessage": "Rebasing worktree onto origin/develop..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.agents/hooks/check-worktree-isolation.sh",
            "timeout": 5,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.agents/hooks/check-python-edit.sh",
            "timeout": 30,
            "statusMessage": "Formatting and type checking edited Python files..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "pyrefly-lsp@local": true
  },
  "extraKnownMarketplaces": {
    "local": {
      "source": {
        "source": "directory",
        "path": ".claude/plugins/pyrefly-lsp"
      }
    }
  },
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "30000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
